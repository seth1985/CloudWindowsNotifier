<Window x:Class="WindowsNotifier.OfflineAuthoring.App.ScriptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Script Editor"
        Height="700"
        Width="1000"
        MinHeight="500"
        MinWidth="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="ScriptTextBox"
                 Grid.Row="0"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13" />

        <DockPanel Grid.Row="1" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Width="100" Margin="8,0,0,0" IsDefault="True" Click="Save_Click">Save</Button>
            <Button DockPanel.Dock="Right" Width="100" IsCancel="True" Click="Cancel_Click">Cancel</Button>
        </DockPanel>
    </Grid>
</Window>
