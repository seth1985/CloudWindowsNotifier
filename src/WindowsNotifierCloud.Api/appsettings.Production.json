{
  "Environment": {
    "Mode": "ProductionCloud"
  },
  "Jwt": {
    "Issuer": "WindowsNotifierCloud",
    "Audience": "WindowsNotifierCloud",
    "Key": "change-this-prod-key",
    "ExpiryMinutes": 120
  },
  "Authentication": {
    "Provider": "Local"
  },
  "Entra": {
    "TenantId": "YOUR_TENANT_ID",
    "Authority": "",
    "ApiAudience": "api://YOUR_API_APP_ID",
    "SpaClientId": "YOUR_SPA_CLIENT_ID",
    "Scope": "api://YOUR_API_APP_ID/access_as_user"
  },
  "Storage": {
    "Root": "%LOCALAPPDATA%\\\\Windows Notifier\\\\ApiStorage",
    "DevCoreModulesRoot": null,
    "Retention": {
      "RetainExportVersions": 3,
      "MaxExportAgeDays": 30,
      "MaxZipAgeDays": 30,
      "PruneOrphans": true
    }
  },
  "Telemetry": {
    "ApiKey": "replace-with-strong-prod-telemetry-key"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=YOUR_PG_HOST;Port=5432;Database=windows_notifier_cloud;Username=YOUR_PG_USER;Password=YOUR_PG_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  }
}
